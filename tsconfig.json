{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop":true,
    "lib": ["es2019", "dom"],
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react",
    "noEmitOnError": true,
    "noUnusedLocals": false,
    "noImplicitAny": false,
    "outDir": "lib",
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "target": "es2015"
  },
  "include": ["src", "src/main.tsx", "src/vite-env.d.ts"]
}
